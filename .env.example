# Backend
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGO_DB=relaix
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_ROOT_USERNAME=root
# Local dev: mongodb://...@localhost:27017/...
# Docker Compose: replace localhost with service name "mongodb"
MONGODB_URI=mongodb://root:CHANGE_ME_STRONG_PASSWORD@localhost:27017/relaix?authSource=admin

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Local dev: redis://:...@localhost:6379
# Docker Compose: replace localhost with service name "redis"
REDIS_URL=redis://:CHANGE_ME_STRONG_PASSWORD@localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
