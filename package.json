{
  "name": "relaix",
  "version": "1.0.0",
  "description": "Monorepo with NestJS backend, Next.js frontend, and shared libraries",
  "private": true,
  "packageManager": "bun@1.2.19",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format",
